{
  "expo": {
    "name": "CalorieCalc",
    "slug": "caloriecalc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.caloriecalc.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CalorieCalc uses the camera to analyze food and calculate nutrition information.",
        "NSPhotoLibraryUsageDescription": "CalorieCalc accesses your photos to analyze food and calculate nutrition information."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E14"
      },
      "package": "com.caloriecalc.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CalorieCalc to access your camera to analyze food."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CalorieCalc to access your photos to analyze food."
        }
      ]
    ],
    "scheme": "caloriecalc",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5a31993a-4b23-4c0a-8a19-db18841778be"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5a31993a-4b23-4c0a-8a19-db18841778be"
    }
  }
}
